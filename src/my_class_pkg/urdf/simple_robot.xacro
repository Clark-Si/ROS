<?xml version="1.0"?>
<robot name="car" xmlns:xacro="http://wiki.ros.org/xacro">

  <!-- 定义常量 -->
  <xacro:property name="wheel_radius" value="0.08" />
  <xacro:property name="wheel_length" value="0.03" />
  <xacro:property name="wheel_separation" value="0.2" />
  <xacro:property name="wheel_diameter" value="0.16" />
  <xacro:property name="caster_radius" value="0.05" />
  
  <!-- 定义颜色 -->
  <xacro:property name="blue_color" value="0.2 0.2 0.8 1" />
  <xacro:property name="gray_color" value="0.5 0.5 0.5 1" />
  <xacro:property name="black_color" value="0 0 0 1" />

  <!-- 轮子宏定义 -->
  <xacro:macro name="wheel" params="name position">
    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder length="${wheel_length}" radius="${wheel_radius}" />
        </geometry>
        <material name="gray">
          <color rgba="${gray_color}" />
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder length="${wheel_length}" radius="${wheel_radius}" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1" />
        <origin rpy="0 0 0" xyz="0 0 0" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
      </inertial>
    </link>
    
    <joint name="${name}_joint" type="revolute">
      <parent link="base_link" />
      <child link="${name}_link" />
      <origin xyz="${position}" rpy="1.5708 0 0" />
      <axis xyz="0 0 1" />
      <limit effort="100" lower="-1000" upper="1000" velocity="10" />
    </joint>
  </xacro:macro>

  <!-- 万向轮宏定义 -->
  <xacro:macro name="caster" params="name position">
    <link name="${name}_link">
      <visual>
        <geometry>
          <sphere radius="${caster_radius}" />
        </geometry>
        <material name="black">
          <color rgba="${black_color}" />
        </material>
      </visual>
      <collision>
        <geometry>
          <sphere radius="${caster_radius}" />
        </geometry>
      </collision>
      <inertial>
        <mass value="0.05" />
        <origin rpy="0 0 0" xyz="0 0 0" />
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001" />
      </inertial>
    </link>
    
    <joint name="${name}_joint" type="fixed">
      <parent link="base_link" />
      <child link="${name}_link" />
      <origin xyz="${position}" />
    </joint>
  </xacro:macro>

  <!-- 底盘 -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.2 0.05" />
      </geometry>
      <material name="blue">
        <color rgba="${blue_color}" />
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.4 0.2 0.05" />
      </geometry>
    </collision>
    <inertial>
      <mass value="1" />
      <origin rpy="0 0 0" xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001" />
    </inertial>
  </link>

  <!-- 使用宏创建轮子 -->
  <xacro:wheel name="wheel_left" position="-0.15 0.1 0" />
  <xacro:wheel name="wheel_right" position="-0.15 -0.1 0" />
  
  <!-- 使用宏创建万向轮 -->
  <xacro:caster name="caster" position="0.15 0 -0.05" />

  <!-- Gazebo插件 -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
        <alwaysOn>true</alwaysOn>
        <leftJoint>wheel_left_joint</leftJoint>
        <rightJoint>wheel_right_joint</rightJoint>
        <wheelSeparation>0.24</wheelSeparation>
        <wheelDiameter>0.2</wheelDiameter>
        <torque>10</torque>
        <commandTopic>cmd_vel</commandTopic>
        <odometryTopic>odom</odometryTopic>
        <odometryFrame>odom</odometryFrame>
        <robotBaseFrame>base_link</robotBaseFrame>
    </plugin>
  </gazebo>

</robot>

